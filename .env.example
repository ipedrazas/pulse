# Shared secret for agent-to-hub authentication
MONITOR_TOKEN=change-me-to-a-strong-secret

# REST API token (optional, defaults to MONITOR_TOKEN if unset)
# REST_TOKEN=change-me-to-a-different-secret

# TimescaleDB credentials
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse
POSTGRES_DB=pulse

# Agent configuration
SERVER_ADDR=api:50051
PROXMOX_NODE_NAME=node-1
POLL_DELAY_SECONDS=10
METADATA_RESYNC_SECONDS=3600

# Comma-separated substrings to match for env var redaction (optional)
# ENV_REDACT_PATTERNS=PASSWORD,SECRET,KEY,TOKEN,CREDENTIAL

# Comma-separated actions the agent is allowed to execute (optional)
# ALLOWED_ACTIONS=compose_update,compose_restart
