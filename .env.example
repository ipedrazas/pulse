# Shared secret for agent-to-hub authentication
MONITOR_TOKEN=change-me-to-a-strong-secret

# REST API token (optional, defaults to MONITOR_TOKEN if unset)
# REST_TOKEN=change-me-to-a-different-secret

# TimescaleDB credentials
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse
POSTGRES_DB=pulse

# Agent configuration
SERVER_ADDR=api:50051
PROXMOX_NODE_NAME=node-1
POLL_DELAY_SECONDS=10
METADATA_RESYNC_SECONDS=3600

# Comma-separated substrings to match for env var redaction (optional)
# ENV_REDACT_PATTERNS=PASSWORD,SECRET,KEY,TOKEN,CREDENTIAL

# Comma-separated actions the agent is allowed to execute (optional)
# ALLOWED_ACTIONS=compose_update,compose_restart

# TLS for gRPC (optional — omit for plaintext)
# Hub: path to TLS certificate and key
# TLS_CERT_FILE=/path/to/server.crt
# TLS_KEY_FILE=/path/to/server.key
# Agent: path to CA certificate for verifying the hub
# TLS_CA_FILE=/path/to/ca.crt

# Webhook notifications (optional — omit to disable)
# URL to POST JSON payloads on container state changes (Slack/Discord/Mattermost compatible)
# WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
# Comma-separated event types to send (default: all)
# Valid events: container_died, container_started, container_removed, agent_offline, agent_online
# WEBHOOK_EVENTS=container_died,container_started,container_removed,agent_offline,agent_online
